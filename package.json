{
  "name": "resume-lm-monorepo",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "pnpm --parallel --filter=@resume-lm/frontend dev",
    "dev:all": "pnpm --parallel --filter='@resume-lm/*' dev",
    "build": "pnpm --filter=@resume-lm/shared build && pnpm --filter=@resume-lm/frontend build && pnpm --filter=@resume-lm/backend build",
    "start": "pnpm --parallel --filter=@resume-lm/frontend --filter=@resume-lm/backend start",
    "lint": "pnpm --recursive lint",
    "frontend:dev": "pnpm --filter=@resume-lm/frontend dev",
    "frontend:build": "pnpm --filter=@resume-lm/frontend build",
    "frontend:start": "pnpm --filter=@resume-lm/frontend start",
    "backend:dev": "pnpm --filter=@resume-lm/backend dev",
    "backend:build": "pnpm --filter=@resume-lm/backend build",
    "backend:start": "pnpm --filter=@resume-lm/backend start",
    "install:all": "pnpm install"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  }
}
