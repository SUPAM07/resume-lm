# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# workspace dependencies
frontend/node_modules
backend/node_modules
shared/node_modules

# testing
/coverage
frontend/coverage
backend/coverage

# next.js
/.next/
/out/
frontend/.next/
frontend/out/

# production
/build
backend/dist/
shared/dist/

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example
!frontend/.env.example
!backend/.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
frontend/next-env.d.ts

.cursorrules
.aider*

.__tests__
/tests